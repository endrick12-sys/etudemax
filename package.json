{
  "name": "etudemax",
  "version": "1.0.0",
  "description": "EtudeMax - Assistant de révision scolaire",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "@capacitor/core": "^5.7.0",
    "@capacitor/camera": "^5.7.0",
    "@capacitor/filesystem": "^5.7.0",
    "@capacitor/android": "^5.7.0",
    "@capacitor/ios": "^5.7.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
